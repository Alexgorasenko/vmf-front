  "scripts": {
    "start": "SKIP_PREFLIGHT_CHECK=true craco start",
    "win_start": "set SKIP_PREFLIGHT_CHECK=true&&craco start",
    "build": "SKIP_PREFLIGHT_CHECK=true INSTANCE=test craco build && compress-cra",
    "release": "SKIP_PREFLIGHT_CHECK=true INSTANCE=prod craco build && compress-cra",
    "win_build": "set SKIP_PREFLIGHT_CHECK=true&&craco build && compress-cra",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "storybook": "start-storybook -p 6006 -s public",
    "build-storybook": "build-storybook -s public"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@storybook/addon-actions": "^6.5.10",
    "@storybook/addon-essentials": "^6.5.10",
